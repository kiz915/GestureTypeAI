              <div class="shortcut"><span>👊</span><small>Caps Lock</small></div>
              <div class="shortcut"><span>🖐</span><small>Stop</small></div>
              <div class="shortcut"><span>👌</span><small>Copy</small></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Gesture Demo Simulator -->
      <div class="gesture-simulator">
        <h3>Try Gestures (Click to simulate)</h3>
        <div class="alpha-grid" id="alphaGrid"></div>
      </div>
    </div>
  </section>

  <!-- GESTURE MAP -->
  <section class="gesture-map" id="gestures">
    <div class="container">
      <div class="section-header">
