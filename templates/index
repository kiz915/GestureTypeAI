  <!-- HERO -->
  <section class="hero" id="home">
    <div class="hero-bg">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="grid-overlay"></div>
    </div>
    <div class="hero-content">
      <div class="badge-pill">
        <span class="pulse-dot"></span>
        AI-Powered · Real-Time · Open Source
      </div>
      <h1 class="hero-title">
        Type with your<br />
        <span class="gradient-text">Hands.</span>
      </h1>
      <p class="hero-sub">
        GestureType AI translates hand gestures into text, signs, and PC controls — powered by MediaPipe &amp; TensorFlow. No keyboard. No mouse. Just you.
      </p>
      <div class="hero-cta">
        <a href="#features" class="btn btn-primary btn-lg">
          <span class="btn-icon">✦</span> Explore Features
        </a>
        <a href="#gestures" class="btn btn-outline btn-lg">Gesture Library</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><strong>26</strong><span>Letters</span></div>
        <div class="stat-div"></div>
        <div class="stat"><strong>50+</strong><span>Gestures</span></div>
        <div class="stat-div"></div>
        <div class="stat"><strong>~98%</strong><span>Accuracy</span></div>
        <div class="stat-div"></div>
        <div class="stat"><strong>Real-Time</strong><span>Processing</span></div>
      </div>
    </div>

    <!-- CAMERA PANEL — moved here from demo section -->
    <div class="hero-visual">
      <div class="hero-cam-wrapper">
        <div class="hero-cam-label">
          <span class="pulse-dot"></span>
          Live Gesture Cam
        </div>
        <div class="camera-frame" id="cameraFrame" style="aspect-ratio:4/3; background:var(--bg-3); border-radius:var(--radius); border:1px solid var(--border); position:relative; overflow:hidden; width:100%; max-width:420px;">
          <div class="camera-placeholder" id="cameraPlaceholder">
            <div class="cam-icon-wrap">
              <div class="cam-ring"></div>
              <span class="cam-icon">📷</span>
            </div>
            <p>Camera is off</p>
            <small>Click below to enable</small>
          </div>
          <video id="webcamVideo" autoplay muted playsinline></video>
          <canvas id="overlayCanvas"></canvas>
          <div class="camera-hud" id="cameraHud" style="display:none;">
            <div class="hud-top">
              <span class="hud-live"><span class="pulse-dot"></span>LIVE</span>
              <span class="hud-fps" id="hudFps">30 FPS</span>
            </div>
            <div class="hud-gesture">
              <span>Detected: </span>
              <strong id="detectedGesture">—</strong>
            </div>
          </div>
        </div>
        <div class="hero-cam-controls">
          <button class="cam-btn" id="camToggle">
            <span class="cam-btn-icon">📷</span>
            <span id="camBtnText">Enable Camera</span>
          </button>
          <button class="cam-btn cam-btn-secondary" id="camFlip">↔ Flip</button>
          <button class="cam-btn cam-btn-secondary" id="camSnapshot">📸</button>
        </div>
        <div class="hero-cam-output">
          <div class="hero-big-letter" id="bigLetter">—</div>
          <div class="confidence-bar" style="padding:0 4px;">
            <span style="font-size:0.75rem;color:var(--text-3);">Confidence</span>
            <div class="bar-track" style="flex:1;"><div class="bar-fill" id="demoBar" style="width:0%"></div></div>
            <span style="font-size:0.75rem;color:var(--text-3);" id="demoConf">—</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What It Does</span>
        <h2>Powerful Features</h2>
        <p>A complete hand-gesture intelligence platform — from typing to PC control.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card feature-large">
          <div class="feature-icon">🔤</div>
          <h3>A–Z Gesture Typing</h3>
          <p>Type every letter of the English alphabet using hand poses. ASL-based mapping with custom gesture training support.</p>
          <div class="feature-tag">Core Feature</div>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🤝</div>
          <h3>Sign Language → Text</h3>
          <p>Real-time ASL & ISL recognition converts signing into readable text instantly.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🖥</div>
          <h3>PC Control</h3>
          <p>Swipe to scroll, pinch to zoom, gesture to copy/paste, switch windows hands-free.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📷</div>
          <h3>Camera Integration</h3>
          <p>One-click camera activation. Works with any webcam. Processes at 30fps locally.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🧠</div>
          <h3>Custom Training</h3>
          <p>Train custom gestures for your own shortcuts, macros, and commands.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🌐</div>
          <h3>Multi-Language</h3>
          <p>Support for ASL, ISL, BSL gesture sets with community-contributed packs.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">♿</div>
          <h3>Accessibility First</h3>
          <p>Designed to empower people with mobility impairments to interact with any computer.</p>
        </div>
        <div class="feature-card feature-large">
          <div class="feature-icon">⚡</div>
          <h3>Edge Processing</h3>
          <p>100% on-device inference. No cloud, no latency, no privacy concerns. Your gestures stay yours.</p>
          <div class="feature-tag">Privacy-Safe</div>
        </div>
      </div>
    </div>
  </section>

  <!-- LIVE DEMO -->
  <section class="demo-section" id="demo">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Interactive</span>
        <h2>Live Demo</h2>
        <p>Enable the camera at the top of the page, then watch your gestures appear as text below.</p>
      </div>

      <div class="demo-layout" style="grid-template-columns:1fr;">
        <!-- Output Panel (full width since camera is in hero) -->
        <div class="output-panel">
          <div class="output-header">
            <span>Text Output</span>
            <div class="output-actions">
              <button class="icon-btn" id="copyOutput" title="Copy">⎘ Copy</button>
              <button class="icon-btn" id="clearOutput" title="Clear">✕ Clear</button>
              <button class="icon-btn" id="speakOutput" title="Speak">🔊 Speak</button>
            </div>
          </div>
          <div class="output-area" id="outputArea">
            <span class="output-placeholder">Your typed text will appear here...</span>
          </div>

          <div class="gesture-mode-tabs" style="margin-top:8px;">
            <button class="mode-tab active" data-mode="typing">✍ Typing</button>
            <button class="mode-tab" data-mode="sign">🤝 Sign Language</button>
            <button class="mode-tab" data-mode="control">🖥 PC Control</button>
          </div>

          <div class="gesture-shortcuts">
            <h4>Quick Gestures</h4>
            <div class="shortcuts-grid">
              <div class="shortcut"><span>✌</span><small>Space</small></div>
              <div class="shortcut"><span>👆</span><small>Enter</small></div>
