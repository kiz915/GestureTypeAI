        <p>Complete ASL-based hand gesture mapping for all 26 letters and control commands.</p>
      </div>

      <div class="gesture-search-bar">
        <input type="text" id="gestureSearch" placeholder="Search gesture... e.g. 'A' or 'scroll'" />
        <select id="gestureFilter">
          <option value="all">All Categories</option>
          <option value="alpha">Alphabet</option>
          <option value="control">PC Control</option>
          <option value="special">Special</option>
        </select>
      </div>

      <div class="gesture-grid" id="gestureGrid"></div>
    </div>
  </section>

