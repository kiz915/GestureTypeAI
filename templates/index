        <h2>Tech Stack</h2>
      </div>
      <div class="tech-grid">
        <div class="tech-card">
          <div class="tech-logo">🖐</div>
          <h4>MediaPipe Hands</h4>
          <p>Google's hand landmark detection — 21 keypoints per hand at 30fps</p>
        </div>
        <div class="tech-card">
          <div class="tech-logo">🧠</div>
          <h4>TensorFlow.js</h4>
          <p>On-device ML inference for gesture classification and custom training</p>
        </div>
        <div class="tech-card">
          <div class="tech-logo">🐍</div>
          <h4>Python + OpenCV</h4>
          <p>Desktop backend for PC control gestures, pyautogui integration</p>
        </div>
        <div class="tech-card">
          <div class="tech-logo">⚡</div>
          <h4>PyAutoGUI</h4>
          <p>Translates recognized gestures into real keyboard and mouse actions</p>
        </div>
        <div class="tech-card">
          <div class="tech-logo">🌐</div>
          <h4>WebRTC</h4>
          <p>Browser camera access with real-time video stream processing</p>
        </div>
        <div class="tech-card">
          <div class="tech-logo">📊</div>
          <h4>NumPy + Sklearn</h4>
          <p>Feature extraction and gesture model training pipeline</p>
        </div>
      </div>

      <div class="architecture-diagram">
        <h3>System Architecture</h3>
        <div class="arch-flow">
          <div class="arch-node">📷<br/><small>Camera Feed</small></div>
          <div class="arch-arrow">→</div>
          <div class="arch-node">🖐<br/><small>Hand Detection</small></div>
          <div class="arch-arrow">→</div>
          <div class="arch-node">📐<br/><small>Landmark Extraction</small></div>
          <div class="arch-arrow">→</div>
          <div class="arch-node">🧠<br/><small>Gesture Classifier</small></div>
          <div class="arch-arrow">→</div>
          <div class="arch-node">⚡<br/><small>Action Output</small></div>
        </div>
      </div>
    </div>
  </section>

  <!-- DOCS / SETUP -->
  <section class="docs-section" id="docs">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Get Started</span>
        <h2>Setup Guide</h2>
      </div>
      <div class="docs-layout">
        <div class="docs-nav">
          <button class="doc-tab active" data-doc="install">Installation</button>
          <button class="doc-tab" data-doc="usage">Usage</button>
          <button class="doc-tab" data-doc="training">Training</button>
          <button class="doc-tab" data-doc="api">API</button>
        </div>
        <div class="docs-content">
          <div class="doc-panel active" id="doc-install">
            <h3>Installation</h3>
            <div class="code-block">
              <div class="code-header"><span>bash</span><button class="copy-code">Copy</button></div>
              <pre><code># Clone the repository
git clone https://github.com/yourusername/gesturetype-ai.git
cd gesturetype-ai

# Create virtual environment
python -m venv venv
source venv/bin/activate  # Windows: venv\Scripts\activate

# Install dependencies
pip install -r requirements.txt</code></pre>
            </div>
            <div class="code-block">
              <div class="code-header"><span>requirements.txt</span><button class="copy-code">Copy</button></div>
              <pre><code>mediapipe==0.10.9
opencv-python==4.8.1.78
tensorflow==2.15.0
pyautogui==0.9.54
numpy==1.26.2
scikit-learn==1.3.2
flask==3.0.0
flask-socketio==5.3.6</code></pre>
            </div>
          </div>

          <div class="doc-panel" id="doc-usage">
            <h3>Running GestureType AI</h3>
            <div class="code-block">
              <div class="code-header"><span>bash</span><button class="copy-code">Copy</button></div>
              <pre><code># Run gesture typing mode
python main.py --mode typing

# Run sign language mode
python main.py --mode sign-language

# Run PC control mode
python main.py --mode pc-control

# Launch web interface
python app.py  # Open http://localhost:5000</code></pre>
            </div>
          </div>

          <div class="doc-panel" id="doc-training">
            <h3>Training Custom Gestures</h3>
            <div class="code-block">
              <div class="code-header"><span>python</span><button class="copy-code">Copy</button></div>
              <pre><code># Collect training data
python collect_data.py --gesture "thumbs_up" --samples 200

# Train the model
python train.py --epochs 50 --model custom_gestures

# Evaluate accuracy
python evaluate.py --model custom_gestures</code></pre>
            </div>
          </div>

          <div class="doc-panel" id="doc-api">
            <h3>Python API</h3>
            <div class="code-block">
              <div class="code-header"><span>python</span><button class="copy-code">Copy</button></div>
              <pre><code>from gesturetype import GestureEngine

# Initialize engine
engine = GestureEngine(mode="typing", camera_id=0)

# Register callback
@engine.on_gesture
def on_gesture(gesture, confidence):
    print(f"Detected: {gesture} ({confidence:.0%})")

# Start recognition
engine.start()

# Stop when done
engine.stop()</code></pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

